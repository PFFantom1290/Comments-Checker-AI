# ── Required ────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional but recommended ─────────────────────────────────────────────────
# Jina AI Reader works WITHOUT a key (~200 req/day per IP on free tier).
# Sign up at https://jina.ai to unlock 1M tokens/month free.
JINA_API_KEY=jina_...

# ScraperAPI — REQUIRED for Amazon (and other CAPTCHA-protected sites).
# Free tier: 5,000 credits/month. Sign up at https://www.scraperapi.com
# Without this key, Amazon URLs will return a clear error message.
SCRAPERAPI_KEY=...

# ── Authentication (NextAuth v5 / Auth.js) — REQUIRED for login ───────────────
# Generate a secret with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=...
AUTH_TRUST_HOST=true

# Google OAuth — optional, enables "Continue with Google".
# Create credentials at https://console.cloud.google.com/apis/credentials
#   • OAuth 2.0 Client ID, type: Web application
#   • Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=...
AUTH_GOOGLE_SECRET=...

# Comma-separated emails granted UNLIMITED scans (admin accounts). Optional.
ADMIN_EMAILS=

# ── Database (Neon serverless Postgres) — REQUIRED ───────────────────────────
# Create a free project at https://neon.tech and paste its connection string.
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Password used by `npm run db:setup` to seed ADMIN_EMAILS accounts. Optional.
ADMIN_SEED_PASSWORD=

# ── Payments (Paddle — Merchant of Record) — REQUIRED to sell scan packs ─────
# Sandbox dashboard: https://sandbox-vendors.paddle.com
NEXT_PUBLIC_PADDLE_ENV=sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
PADDLE_API_KEY=...
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
# Price ids — create with `npm run paddle:setup`, or in the Paddle dashboard.
PADDLE_PRICE_BASIC=pri_...
PADDLE_PRICE_PLUS=pri_...
PADDLE_PRICE_PRO=pri_...
PADDLE_PRICE_ULTRA=pri_...

# ── Cache + rate limiting (Upstash Redis) — optional but recommended in prod ──
# Without these the review cache and per-IP limiter run in-memory, which barely
# works on Vercel (each serverless instance is separate) — so cached products
# get re-analyzed and re-billed to OpenAI. Create a free database at
# https://upstash.com (or add the Upstash integration in Vercel, which sets
# these automatically). Both are needed together.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
